---
import { ACQUISITION_MAILTO } from '../config/site';
---

<section class="pt-20 pb-16 md:pt-24 md:pb-20 border-b border-white/10 creative-grid">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-3xl bg-white/5 border border-white/10 mb-6">
      <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
      <span class="text-xs font-medium tracking-[1.5px] text-emerald-400">PREMIUM DOMAIN • STRATEGIC ACQUISITION</span>
    </div>

    <h1 class="font-display text-[3.25rem] md:text-[4.75rem] leading-[0.95] tracking-[-0.055em] mb-4">
      <span class="text-white">Tinkle</span><span class="trailer-text">Trailers</span><span class="text-white">.com</span>
    </h1>

    <p class="max-w-2xl mx-auto text-2xl md:text-3xl font-medium tracking-tight text-zinc-300 mb-8">
      The definitive domain for<br class="hidden md:block" />mobile trailer &amp; portable solutions.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href={ACQUISITION_MAILTO}
        class="group w-full sm:w-auto inline-flex items-center justify-center gap-x-3 px-9 py-4 text-lg font-semibold rounded-3xl bg-white text-zinc-950 hover:bg-zinc-100 active:scale-[0.985] transition-all shadow-xl shadow-black/20"
      >
        <span>Acquire for $95,000</span>
        <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
      </a>
      <a
        href="#why"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-x-2 px-8 py-4 text-lg font-medium rounded-3xl border border-white/20 hover:bg-white/5 transition-all"
      >
        <span>Explore the opportunity</span>
      </a>
    </div>

    <div class="flex items-center justify-center gap-x-8 text-sm text-zinc-500">
      <div class="flex items-center gap-x-2">
        <i class="fa-solid fa-check text-emerald-400"></i>
        <span>Instant brand recognition</span>
      </div>
      <div class="flex items-center gap-x-2">
        <i class="fa-solid fa-check text-emerald-400"></i>
        <span>Premium .com TLD</span>
      </div>
      <div class="flex items-center gap-x-2">
        <i class="fa-solid fa-check text-emerald-400"></i>
        <span>Category-defining</span>
      </div>
    </div>
  </div>
</section>
