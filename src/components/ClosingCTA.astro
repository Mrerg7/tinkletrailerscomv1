---
import { ACQUISITION_MAILTO } from '../config/site';
---

<section class="border-t border-white/10 bg-zinc-900 py-16">
  <div class="max-w-xl mx-auto px-6 text-center">
    <h2 class="font-display text-4xl tracking-tighter mb-4">Ready to own the future of mobile trailer solutions?</h2>
    <p class="text-zinc-400 mb-8">This domain will not be available long. Secure it before your competitors do.</p>

    <a
      href={ACQUISITION_MAILTO}
      class="inline-flex items-center justify-center gap-x-3 px-10 h-14 rounded-3xl bg-white text-zinc-950 font-semibold text-lg hover:bg-zinc-100 active:scale-[0.985] transition-all shadow-xl"
    >
      Start the conversation
      <i class="fa-solid fa-arrow-right"></i>
    </a>

    <div class="mt-6 text-xs text-zinc-500">Direct from owner • Confidential inquiries welcome</div>
  </div>
</section>
