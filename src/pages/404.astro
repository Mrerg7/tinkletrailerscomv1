---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Tinkle Trailers"
  description="The page you are looking for could not be found."
  robots="noindex"
>
  <main class="min-h-screen flex items-center justify-center">
    <div class="text-center px-6">
      <h1 class="font-display text-8xl tracking-tighter mb-4">404</h1>
      <p class="text-xl text-zinc-400 mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a
        href="/"
        class="inline-flex items-center gap-x-2 px-6 py-3 bg-white text-zinc-950 font-medium rounded-2xl hover:bg-zinc-100 transition-all"
      >
        <i class="fa-solid fa-arrow-left"></i>
        Back to Home
      </a>
    </div>
  </main>
</BaseLayout>
